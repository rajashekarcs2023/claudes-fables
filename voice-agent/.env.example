# LiveKit Cloud project (cloud.livekit.io). Speech (Cartesia TTS, Deepgram STT)
# runs through LiveKit Inference, so these are the only secrets you need.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match AGENT_NAME in the web app's env so the room dispatches to us.
AGENT_NAME=fable-teller

# Optional voice tuning (Cartesia voice id + models).
# FABLE_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
# FABLE_TTS_MODEL=cartesia/sonic-3
# FABLE_STT_MODEL=deepgram/nova-3
